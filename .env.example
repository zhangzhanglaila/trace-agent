# 复制本文件为 .env 并填入真实值；.env 已被 .gitignore 忽略，不会进 git。
# 用法：examples/single_run_langgraph.py 会读取 DEEPSEEK_API_KEY。
#   Windows PowerShell:  $env:DEEPSEEK_API_KEY="sk-xxx"; python examples/single_run_langgraph.py
#   Git Bash / Linux:    DEEPSEEK_API_KEY=sk-xxx PYTHONPATH=. python examples/single_run_langgraph.py

DEEPSEEK_API_KEY=sk-your-key-here
